<UserControl x:Class="PitLeague.SimHub.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent" FontFamily="Segoe UI" FontSize="13">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
        <StackPanel Margin="16">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="🏁 PitLeague" FontSize="22" FontWeight="Bold" Foreground="#E53935"/>
                <TextBlock x:Name="TxtVersion" Text=" v1.0.0" FontSize="14"
                           Foreground="#888" VerticalAlignment="Bottom" Margin="4,0,0,2"/>
            </StackPanel>

            <!-- Status atual -->
            <Border Background="#1E1E1E" CornerRadius="8" Padding="12" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Status" Foreground="#888" FontSize="11" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TxtStatus" Text="Aguardando corrida..."
                               Foreground="#FFFFFF" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Ellipse x:Name="EllipseConnected" Width="10" Height="10"
                                 Fill="#555" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtConnected" Text="Não verificado"
                                   Foreground="#888" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ─── Seção: Configuração da API ─────────────────────────────── -->
            <TextBlock Text="CONFIGURAÇÃO DA API" Foreground="#E53935"
                       FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>

            <!-- API Key -->
            <TextBlock Text="API Key" Foreground="#AAA" FontSize="11" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="TxtApiKey" Grid.Column="0"
                             Background="#1E1E1E" Foreground="White"
                             BorderBrush="#444" Padding="8,6"
                             PasswordChanged="TxtApiKey_Changed"/>
                <Button x:Name="BtnTest" Content="Testar" Grid.Column="1"
                        Margin="8,0,0,0" Background="#333" Foreground="White"
                        BorderBrush="#555" Padding="8,6"
                        Click="BtnTest_Click" Cursor="Hand"/>
            </Grid>

            <!-- League ID -->
            <TextBlock Text="League ID" Foreground="#AAA" FontSize="11" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtLeagueId" Background="#1E1E1E" Foreground="White"
                     BorderBrush="#444" Padding="8,6" Margin="0,0,0,4"
                     TextChanged="TxtLeagueId_Changed"/>
            <TextBlock Text="Encontre em: Admin → Configurações → Integrações → SimHub"
                       Foreground="#666" FontSize="10" Margin="0,0,0,16"/>

            <!-- ─── Seção: Jogo ─────────────────────────────────────────────── -->
            <TextBlock Text="JOGO" Foreground="#E53935"
                       FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>

            <TextBlock Text="Nome do jogo (para exibição)" Foreground="#AAA"
                       FontSize="11" Margin="0,0,0,4"/>
            <ComboBox x:Name="CmbGame" Background="#1E1E1E" Foreground="White"
                      BorderBrush="#444" Padding="8,6" Margin="0,0,0,16"
                      SelectionChanged="CmbGame_Changed">
                <ComboBoxItem Content="F1 25"/>
                <ComboBoxItem Content="F1 24"/>
                <ComboBoxItem Content="ACC (Assetto Corsa Competizione)"/>
                <ComboBoxItem Content="iRacing"/>
                <ComboBoxItem Content="AMS2 (Automobilista 2)"/>
                <ComboBoxItem Content="rFactor 2"/>
                <ComboBoxItem Content="Le Mans Ultimate"/>
                <ComboBoxItem Content="MotoGP 24"/>
                <ComboBoxItem Content="Outro"/>
            </ComboBox>

            <!-- ─── Seção: Comportamento ───────────────────────────────────── -->
            <TextBlock Text="COMPORTAMENTO" Foreground="#E53935"
                       FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>

            <CheckBox x:Name="ChkAutoSend" Content="Enviar resultado automaticamente ao fim da corrida"
                      Foreground="White" Margin="0,0,0,8"
                      Click="ChkAutoSend_Click"/>

            <CheckBox x:Name="ChkRaceOnly" Content="Apenas sessões de corrida (ignorar Treino/Quali)"
                      Foreground="White" Margin="0,0,0,8"
                      Click="ChkRaceOnly_Click"/>

            <CheckBox x:Name="ChkDebug" Content="Modo debug (logs detalhados no SimHub)"
                      Foreground="White" Margin="0,0,0,16"
                      Click="ChkDebug_Click"/>

            <!-- Mínimo de pilotos -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Mínimo de pilotos para enviar:" Foreground="#AAA"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBox x:Name="TxtMinDrivers" Width="50"
                         Background="#1E1E1E" Foreground="White"
                         BorderBrush="#444" Padding="6,4" TextAlignment="Center"
                         TextChanged="TxtMinDrivers_Changed"/>
            </StackPanel>

            <!-- ─── Ação: Enviar resultado ─────────────────────────────────── -->
            <Separator Background="#333" Margin="0,0,0,16"/>

            <Button x:Name="BtnSendResult" Content="🚀  Enviar Resultado Agora"
                    Background="#E53935" Foreground="White" FontWeight="Bold"
                    FontSize="15" Padding="16,12" BorderThickness="0"
                    Click="BtnSendResult_Click" Cursor="Hand" Margin="0,0,0,8"/>

            <TextBlock x:Name="TxtReadyHint"
                       Text="⚠ Nenhuma corrida finalizada detectada nesta sessão."
                       Foreground="#888" FontSize="11" TextWrapping="Wrap"
                       Margin="0,0,0,8"/>

            <Button x:Name="BtnCaptureNow"
                    Content="📸  Capturar Resultado Agora (spectator/broadcaster)"
                    Background="#2B5797" Foreground="White" FontWeight="Bold"
                    FontSize="12" Padding="12,10" BorderThickness="0"
                    Click="BtnCaptureNow_Click" Cursor="Hand" Margin="0,0,0,4"
                    ToolTip="Força captura do estado atual mesmo fora de Race. Útil para admins, broadcasters ou casos onde o jogo fechou antes da transição normal."/>
            <TextBlock Text="Use se você é broadcaster/admin e o fim de corrida não foi detectado automaticamente."
                       Foreground="#666" FontSize="10" TextWrapping="Wrap"
                       Margin="0,0,0,16"/>

            <!-- ─── Último envio ───────────────────────────────────────────── -->
            <Border Background="#1A1A1A" CornerRadius="6" Padding="10" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Último envio" Foreground="#666" FontSize="10" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TxtLastSent" Text="Nunca enviado"
                               Foreground="#AAA" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Footer -->
            <TextBlock Text="pitleague.com.br" Foreground="#444"
                       FontSize="10" HorizontalAlignment="Center"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
